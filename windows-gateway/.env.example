# Cấu hình cổng chạy Windows Gateway
PORT=18080

# API Key để xác thực với Backend (Spring Boot)
API_KEY=secret

# URL của Agent Downloader thực tế chạy ở máy local
AGENT_URL=http://127.0.0.1:1234/api/download/file/browser/public

# Thời gian timeout khi tải file (milliseconds)
DOWNLOAD_TIMEOUT_MS=120000
